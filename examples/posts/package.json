{
  "name": "nuxt-app",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "pnpm run test:sqlite",
    "test:sqlite": "NUXT_PUBLIC_AUTOADMIN_TITLE='Autoadmin Example' vitest",
    "test:postgresql": "NUXT_DATABASE_DIALECT=postgresql NUXT_PUBLIC_AUTOADMIN_TITLE='Autoadmin Example' vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@tiptap/y-tiptap": "^3.0.2",
    "drizzle-orm": "^0.44.4",
    "nuxt": "^4.3.1",
    "pg": "^8.16.3",
    "vue": "^3.5.17",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^3.19.2",
    "@vue/test-utils": "^2.4.6",
    "drizzle-kit": "^0.31.4",
    "playwright-core": "^1.54.1",
    "vitest": "^3.2.4"
  }
}
